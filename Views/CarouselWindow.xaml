<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CSD.Views.CarouselWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CSD"
    xmlns:views="using:CSD.Views"
    xmlns:models="using:CSD.Models"
    xmlns:services="using:CSD.Services"
    xmlns:helpers="using:CSD.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="轮播">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏 -->
        <Grid x:Name="AppTitleBar" Grid.Row="0"
            MinHeight="52" Padding="0,8,0,8"
            VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftInsetColumn" Width="0" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition x:Name="RightInsetColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1"
                Margin="24,0,16,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <FontIcon Glyph="&#xE8B2;"
                    FontSize="16"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="课堂轮播展示"
                    FontSize="15"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- 顶部进度指示 -->
        <TextBlock x:Name="CarouselProgressText" Grid.Row="1"
            TextAlignment="Center" FontSize="16" Margin="0,20,0,0"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- 轮播内容区域 -->
        <Grid Grid.Row="2" Tapped="CarouselOverlay_Tapped">
            <ScrollViewer VerticalAlignment="Center"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Padding="64,0,64,0">
                <StackPanel x:Name="CarouselContentPanel"
                    HorizontalAlignment="Center"
                    Spacing="40"
                    MaxWidth="1200">
                    <!-- 科目名称 -->
                    <TextBlock x:Name="CarouselSubjectText"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Center"
                        FontWeight="Bold"
                        HorizontalAlignment="Center" />
                    <!-- 分隔线 -->
                    <Border Height="2"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        CornerRadius="1"
                        HorizontalAlignment="Center"
                        Width="120" />
                    <!-- 作业内容（使用 ContentControl 承载 RichTextBlock） -->
                    <ContentControl x:Name="CarouselContentHost"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        IsTabStop="False" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 底部退出按钮 -->
        <Button x:Name="ExitCarouselButton" Grid.Row="3"
            Content="✕ 退出轮播"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,24"
            Click="ExitCarouselButton_Click"
            Padding="20,10" />
    </Grid>
</Window>
