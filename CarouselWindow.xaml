<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CSD.CarouselWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CSD"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="轮播">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部进度指示 -->
        <TextBlock x:Name="CarouselProgressText" Grid.Row="0"
            TextAlignment="Center" FontSize="16" Margin="0,20,0,0"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- 轮播内容区域 -->
        <Grid Grid.Row="1" Tapped="CarouselOverlay_Tapped">
            <ScrollViewer VerticalAlignment="Center"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Padding="64,0,64,0">
                <StackPanel x:Name="CarouselContentPanel"
                    HorizontalAlignment="Center"
                    Spacing="40"
                    MaxWidth="1200">
                    <!-- 科目名称 -->
                    <TextBlock x:Name="CarouselSubjectText"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Center"
                        FontWeight="Bold"
                        HorizontalAlignment="Center" />
                    <!-- 分隔线 -->
                    <Border Height="2"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        CornerRadius="1"
                        HorizontalAlignment="Center"
                        Width="120" />
                    <!-- 作业内容（使用 ContentControl 承载 RichTextBlock） -->
                    <ContentControl x:Name="CarouselContentHost"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        IsTabStop="False" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 底部退出按钮 -->
        <Button x:Name="ExitCarouselButton" Grid.Row="2"
            Content="✕ 退出轮播"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,24"
            Click="ExitCarouselButton_Click"
            Padding="20,10" />
    </Grid>
</Window>
