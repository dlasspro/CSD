<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CSD.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CSD"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CSD">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 融入窗口内容区的标题栏 -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            MinHeight="52"
            Padding="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftInsetColumn" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightInsetColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="1"
                Margin="24,0,16,0"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Spacing="0">
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="CSD" />
                <TextBlock
                    x:Name="StatusText"
                    Margin="0,-1,0,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="正在加载今日作业..."
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <!-- 主内容 -->
        <Grid Grid.Row="1" Padding="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: 时间卡片 -->
            <Border
                x:Name="TimeCard"
                Grid.Row="0"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                Margin="0,0,0,12"
                Padding="20,14"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock
                        x:Name="TimeCardClockText"
                        FontSize="28"
                        FontWeight="SemiBold"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="TimeCardDateText"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Row 1: 作业卡片 -->
            <ScrollViewer
                Grid.Row="1"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="HomeworkContainer" Spacing="14">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>
            </ScrollViewer>

            <!-- Row 2: 底部导航栏（含空作业按钮） -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 空作业按钮 -->
                <StackPanel
                    x:Name="UndoneHomeworkPanel"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8"
                    Spacing="8">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>

                <!-- 导航控件 -->
                <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="PrevDateButton"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Click="PrevDateButton_Click"
                    Content="◀"
                    Margin="0,0,8,0" />

                <Button
                    x:Name="DatePickerButton"
                    Grid.Column="1"
                    HorizontalAlignment="Left"
                    Padding="14,10"
                    MinWidth="220"
                    Tag="DisableHoverAnimation">
                    <Button.Flyout>
                        <Flyout
                            x:Name="DateFlyout"
                            Placement="Top"
                            Opening="DateFlyout_Opening">
                            <CalendarView
                                x:Name="DateCalendarView"
                                SelectionMode="Single"
                                IsGroupLabelVisible="True"
                                MinWidth="320"
                                SelectedDatesChanged="DateCalendarView_SelectedDatesChanged" />
                        </Flyout>
                    </Button.Flyout>

                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="CurrentDateTitleText"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="今日作业" />
                        <TextBlock
                            x:Name="TodayKeyText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="点击选择日期" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="NextDateButton"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Click="NextDateButton_Click"
                    Content="▶"
                    Margin="8,0,0,0" />

                <Button
                    x:Name="SyncButton"
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Click="RefreshHomeworkButton_Click"
                    Content="同步"
                    Margin="0,0,8,0" />

                <Button
                    x:Name="ToggleCarouselButton"
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    Click="ToggleCarouselButton_Click"
                    Content="轮播" />

                <Button
                    x:Name="PickRandomStudentButton"
                    Grid.Column="6"
                    VerticalAlignment="Center"
                    Click="PickRandomStudentButton_Click"
                    Content="随机抽取"
                    Margin="8,0,0,0" />

                <Button
                    x:Name="ToggleFullscreenButton"
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    Click="ToggleFullscreenButton_Click"
                    Content="全屏"
                    Margin="8,0,0,0" />
            </Grid>

                <!-- 空作业按钮 -->
                <StackPanel
                    Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,0"
                    Spacing="12">
                    <Button
                        x:Name="TutorialButton"
                        Click="TutorialButton_Click"
                        Content="教程" />
                    <Button
                        x:Name="AboutButton"
                        Click="AboutButton_Click"
                        Content="关于" />
                    <Button
                        Click="OpenSettingsButton_Click"
                        Content="设置" />
                </StackPanel>
            </Grid>

            <!-- 右下角：仅叠在主内容区，避免与标题栏 StatusText 重叠；置于最上层 -->
            <Border
                x:Name="PolicyToastRoot"
                Grid.Row="0"
                Grid.RowSpan="3"
                Canvas.ZIndex="50"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,8,12"
                Padding="16,14"
                MinWidth="280"
                MaxWidth="380"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="PolicyToastTitle"
                        FontSize="14"
                        FontWeight="SemiBold"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="PolicyToastSubtitle"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 轮播覆盖层 -->
        <Grid
            x:Name="CarouselOverlay"
            Visibility="Collapsed"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            Tapped="CarouselOverlay_Tapped">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 底部退出按钮 -->
            <Button
                x:Name="ExitCarouselButton"
                Grid.Row="2"
                Content="✕ 退出轮播"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,16,16"
                Click="ExitCarouselButton_Click" />

            <!-- 轮播内容 -->
            <ScrollViewer
                Grid.Row="1"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <StackPanel
                    x:Name="CarouselContentPanel"
                    Spacing="32"
                    Padding="48">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                    <TextBlock
                        x:Name="CarouselSubjectText"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Center"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="CarouselContentText"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Center" />
                </StackPanel>
            </ScrollViewer>

            <!-- 底部进度 -->
            <TextBlock
                x:Name="CarouselProgressText"
                Grid.Row="2"
                TextAlignment="Center"
                Margin="0,0,0,24"
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Grid>
</Window>
