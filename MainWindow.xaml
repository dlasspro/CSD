<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CSD.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CSD"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CSD">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!-- 主内容 -->
        <Grid Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: 作业卡片 -->
            <ScrollViewer
                Grid.Row="0"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="HomeworkContainer" Spacing="14" />
            </ScrollViewer>

            <!-- Row 1: 状态文字 -->
            <TextBlock
                x:Name="StatusText"
                Grid.Row="1"
                Margin="0,12,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="正在加载今日作业..." />

            <!-- Row 2: 未完成作业按钮 -->
            <StackPanel
                x:Name="UndoneHomeworkPanel"
                Grid.Row="2"
                Orientation="Horizontal"
                Margin="0,12,0,0"
                Spacing="8" />

            <!-- Row 3: 底部导航栏 -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="PrevDateButton"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Click="PrevDateButton_Click"
                    Content="◀"
                    Margin="0,0,8,0" />

                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock
                        FontSize="32"
                        FontWeight="SemiBold"
                        Text="作业" />
                    <TextBlock
                        x:Name="TodayKeyText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Button
                    x:Name="NextDateButton"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Click="NextDateButton_Click"
                    Content="▶"
                    Margin="8,0,0,0" />

                <Button
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Click="RefreshHomeworkButton_Click"
                    Content="刷新"
                    Margin="0,0,8,0" />

                <Button
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    Click="OpenSettingsButton_Click"
                    Content="设置"
                    Margin="0,0,8,0" />

                <Button
                    x:Name="ToggleCarouselButton"
                    Grid.Column="6"
                    VerticalAlignment="Center"
                    Click="ToggleCarouselButton_Click"
                    Content="轮播" />

                <Button
                    x:Name="PickRandomStudentButton"
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    Click="PickRandomStudentButton_Click"
                    Content="随机抽取"
                    Margin="8,0,0,0" />
            </Grid>
        </Grid>

        <!-- 轮播覆盖层 -->
        <Grid
            x:Name="CarouselOverlay"
            Visibility="Collapsed"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            Tapped="CarouselOverlay_Tapped">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 顶部退出按钮 -->
            <Button
                x:Name="ExitCarouselButton"
                Grid.Row="0"
                Content="✕ 退出轮播"
                HorizontalAlignment="Right"
                Margin="0,16,16,0"
                Click="ExitCarouselButton_Click" />

            <!-- 轮播内容 -->
            <ScrollViewer
                Grid.Row="1"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <StackPanel
                    x:Name="CarouselContentPanel"
                    Spacing="32"
                    Padding="48">
                    <TextBlock
                        x:Name="CarouselSubjectText"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Center"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="CarouselContentText"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Center" />
                </StackPanel>
            </ScrollViewer>

            <!-- 底部进度 -->
            <TextBlock
                x:Name="CarouselProgressText"
                Grid.Row="2"
                TextAlignment="Center"
                Margin="0,0,0,24"
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Grid>
</Window>